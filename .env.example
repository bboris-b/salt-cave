# URL canonico del sito (SEO, JSON-LD, Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Numero WhatsApp per prenotazioni (solo cifre, con prefisso paese, senza +)
NEXT_PUBLIC_WHATSAPP_PHONE=

# Social (opzionali — usati nel footer e nello schema.org sameAs)
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=

# Link diretto Google Maps (opzionale)
NEXT_PUBLIC_GOOGLE_MAPS_URL=
